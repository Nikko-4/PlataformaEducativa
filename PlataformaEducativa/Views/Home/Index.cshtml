@{
    ViewData["Title"] = "Inicio";
}


<section class="section text-center mt-5">
    <h2 class="mb-3" style="font-family: 'Montserrat', sans-serif;">Descubre nuestras funcionalidades</h2>
    <p class="lead mb-4">Explora cursos, recursos y herramientas diseñadas para potenciar tu aprendizaje de manera profesional y moderna.</p>
    <a href="@Url.Action("About", "Home")" class="btn btn-primary btn-lg">Ver más</a>
</section>


<section class="section py-5">
    <div class="container-main">
        <div class="row g-4">
            
            <div class="col-md-6">
                <div class="card p-4 text-center">
                    <h5 class="card-title">Cursos Interactivos</h5>
                    <p class="card-text">Aprende con ejercicios prácticos y ejemplos reales que refuerzan tu conocimiento.</p>
                    <a href="@Url.Action("Index", "Cursos")" class="btn btn-primary btn-sm mt-2">Ver cursos</a>
                </div>
            </div>

            
            <div class="col-md-6">
                <div class="card p-4 text-center">
                    <h5 class="card-title">Recursos Multimedia</h5>
                    <p class="card-text">Accede a videos, tutoriales y documentación de calidad para cada tema.</p>
                    <a href="@Url.Action("Index", "Lecciones")" class="btn btn-primary btn-sm mt-2">Explorar lecciones</a>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="section text-center py-5" style="background-color:#0d6efd; color:#fff; border-radius:12px;">
    <div class="container-main d-flex align-items-center justify-content-center" style="min-height:160px;">
        <div class="text-center" style="max-width:720px;">
            <h3 class="mb-3" style="font-family: 'Montserrat', sans-serif;">Únete y empieza tu aprendizaje</h3>
            <p class="mb-0">Regístrate ahora y accede a todos nuestros cursos y recursos.</p>
        </div>
    </div>
</section>


<section class="section py-5">
    <div class="container-main">
        <h4 class="text-center mb-5" style="font-family: 'Montserrat', sans-serif;">Lo que dicen nuestros usuarios</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <p>"La mejor plataforma educativa que he usado. Muy intuitiva y profesional."</p>
                    <small>- Ana P.</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <p>"Gracias a los cursos, pude mejorar mis habilidades rápidamente."</p>
                    <small>- Luis M.</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <p>"Muy buen soporte y contenido de calidad, recomendado 100%."</p>
                    <small>- Marta R.</small>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="section py-5">
    <div class="container-main">
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="card p-3">
                    <h6 class="card-title">Profesional</h6>
                    <p class="card-text">Diseño corporativo y herramientas avanzadas para tu aprendizaje.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3">
                    <h6 class="card-title">Interactivo</h6>
                    <p class="card-text">Contenido dinámico con ejercicios prácticos en tiempo real.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3">
                    <h6 class="card-title">Flexible</h6>
                    <p class="card-text">Accede a tus cursos desde cualquier dispositivo, en cualquier momento.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3">
                    <h6 class="card-title">Seguridad</h6>
                    <p class="card-text">Tus datos y progreso siempre protegidos con la última tecnología.</p>
                </div>
            </div>
        </div>
    </div>
</section>