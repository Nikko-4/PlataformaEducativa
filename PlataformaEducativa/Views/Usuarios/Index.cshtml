@@model IEnumerable<PlataformaEducativa.Models.Usuario>

    @{
        ViewBag.Title = "Usuarios";
    }

    <h2>Usuarios</h2>

    <p>
        @Html.ActionLink("Crear nuevo usuario", "Create")
    </p>

    <table class="table">
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Activo</th>
            <th>Fecha Registro</th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Apellidos</td>
                <td>@item.Email</td>
                <td>@item.Rol</td>
                <td>@item.Activo</td>
                <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                <td>
                    @Html.ActionLink("Detalles", "Details", new { id = item.Id }) |
                    @Html.ActionLink("Editar", "Edit", new { id = item.Id }) |
                    @Html.ActionLink("Eliminar", "Delete", new { id = item.Id })
                </td>
            </tr>
        }
    </table>
