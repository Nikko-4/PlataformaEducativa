@model PlataformaEducativa.Models.Usuarios

@{
    ViewBag.Title = "Detalles del Usuario";
}

<h2>Detalles del Usuario</h2>

<div>
    <dl class="dl-horizontal">
        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        <dt>Apellidos</dt>
        <dd>@Model.Apellidos</dd>

        <dt>Email</dt>
        <dd>@Model.Email</dd>

        <dt>Rol</dt>
        <dd>@Model.Rol</dd>

        <dt>Activo</dt>
        <dd>@Model.Activo</dd>

        <dt>Fecha Registro</dt>
        <dd>@Model.FechaRegistro.ToString("dd/MM/yyyy")</dd>
    </dl>
</div>

<p>
    @Html.ActionLink("Editar", "Edit", new { id = Model.Id }) |
    @Html.ActionLink("Volver al listado", "Index")
</p>