@model PlataformaEducativa.Models.Leccion

@{
    ViewBag.Title = "Eliminar Lección";
}

<h2>Eliminar Lección</h2>

<h3>¿Está seguro que desea eliminar esta lección?</h3>

<div>
    <h4>@Model.Titulo</h4>
    <p><strong>Curso:</strong> @Model.Curso.Titulo</p>
    <p><strong>Orden:</strong> @Model.Orden</p>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="submit" value="Eliminar" class="btn btn-danger" />
    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
}